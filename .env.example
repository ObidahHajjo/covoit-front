# Base URL used by the frontend for all API requests.
# In local nginx setup this usually points to the frontend domain,
# which proxies API routes to the Laravel backend.
VITE_API_BASE_URL=http://covoit.local

# Reverb / WebSocket public app key used by Laravel Echo.
VITE_REVERB_APP_KEY=local-key

# Public host the browser should use for WebSocket connections.
# If nginx proxies Reverb through covoit.local, keep this as covoit.local.
VITE_REVERB_HOST=covoit.local

# HTTP port used by the proxied Reverb endpoint.
VITE_REVERB_PORT=80

# Explicit WS port for non-TLS websocket connections.
VITE_REVERB_WS_PORT=80

# Explicit WSS port for TLS websocket connections.
VITE_REVERB_WSS_PORT=443

# Public scheme used by the browser for Reverb.
# Use http for local non-TLS setups, https when served behind SSL.
VITE_REVERB_SCHEME=http
